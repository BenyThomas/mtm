##
# Default environment configuration for the Money Trust Microfinance app.
#
# VITE_API_URL defines the base URL for the Fineract backend.  The Vite
# development server proxy uses this value to forward requests when you
# run `npm run dev`.  In production builds you can set this variable on
# your deployment environment without rebuilding the app.
VITE_API_URL=https://fineract.epikx.co.tz/fineract-provider
#VITE_API_URL=https://localhost:8443/fineract-provider

##
# Gateway (digital-platform) back-office API base URL.
# If not set, the app uses the Vite dev proxy at /gw (configured in vite.config.js).
# Example: http://localhost:8084
VITE_GATEWAY_API_URL=http://localhost:8084

##
# The tenant identifier required by Fineract.  All API requests must
# include the `Fineract-Platform-TenantId` header.  Change this value
# according to your deployment (e.g. `tenanta`, `tenantb`).
VITE_TENANT=default
